{
    "name": "MMDiary VR Video Player - Oculus Touch",
    "description": "Default bindings for Oculus Touch Controllers",
    "controller_type": "oculus_touch",
    "category": "steamvr_input",
    "binding": {
        "/actions/video": {
            "sources": [
                {
                    "inputs": {
                        "click": {
                            "output": "/actions/video/in/recenter"
                        }
                    },
                    "mode": "button",
                    "path": "/user/hand/right/input/trigger"
                },
                {
                    "inputs": {
                        "click": {
                            "output": "/actions/video/in/recenter"
                        }
                    },
                    "mode": "button",
                    "path": "/user/hand/left/input/trigger"
                },
                {
                    "inputs": {
                        "click": {
                            "output": "/actions/video/in/play_pause"
                        }
                    },
                    "mode": "button",
                    "path": "/user/hand/right/input/menu"
                },
                {
                    "inputs": {
                        "click": {
                            "output": "/actions/video/in/play_pause"
                        }
                    },
                    "mode": "button",
                    "path": "/user/hand/left/input/menu"
                },
                {
                    "inputs": {
                        "position": {
                            "output": "/actions/video/in/seek_axis"
                        }
                    },
                    "mode": "joystick",
                    "path": "/user/hand/right/input/joystick"
                },
                {
                    "inputs": {
                        "position": {
                            "output": "/actions/video/in/seek_axis"
                        }
                    },
                    "mode": "joystick",
                    "path": "/user/hand/left/input/joystick"
                },
                {
                    "inputs": {
                        "click": {
                            "output": "/actions/video/in/grip_modifier"
                        }
                    },
                    "mode": "button",
                    "path": "/user/hand/right/input/grip"
                },
                {
                    "inputs": {
                        "click": {
                            "output": "/actions/video/in/grip_modifier"
                        }
                    },
                    "mode": "button",
                    "path": "/user/hand/left/input/grip"
                }
            ]
        }
    }
}