{
    "version": "1.0.0",
    "name": "MMDiary VR Video Player",
    "description": "Video playback controls for VR",
    "actions": [
        {
            "name": "/actions/video/in/recenter",
            "type": "boolean"
        },
        {
            "name": "/actions/video/in/play_pause", 
            "type": "boolean"
        },
        {
            "name": "/actions/video/in/seek_axis",
            "type": "vector2"
        },
        {
            "name": "/actions/video/in/grip_modifier",
            "type": "boolean"
        }
    ],
    "action_sets": [
        {
            "name": "/actions/video",
            "usage": "single"
        }
    ],
    "default_bindings": [
        {
            "controller_type": "knuckles",
            "binding_url": "vr_action_bindings_knuckles.json"
        },
        {
            "controller_type": "oculus_touch",
            "binding_url": "vr_action_bindings_oculus_touch.json"
        },
        {
            "controller_type": "generic",
            "binding_url": "vr_action_bindings_generic.json"
        }
    ],
    "localization": [
        {
            "language_tag": "en_US",
            "/actions/video": "Video Controls",
            "/actions/video/in/recenter": "Recenter View",
            "/actions/video/in/play_pause": "Play/Pause", 
            "/actions/video/in/seek_axis": "Seek/Zoom Control",
            "/actions/video/in/grip_modifier": "Modifier (Grip)"
        }
    ]
}